            <td style="text-align: right; font-weight: bold; color: #4B0082;">{gia_tri_ban:,.0f} đ</td>
        </tr>
        <tr style="border-bottom: 1px solid #F3E5F5;">
            <td style="padding: 15px; color: #6A5ACD;">Thuế giao dịch (0.1% giá trị bán)</td>
            <td style="text-align: right; color: #BA55D3;">{thue_ban:,.0f} đ</td>
        </tr>
        <tr style="border-bottom: 1px solid #F3E5F5;">
            <td style="padding: 15px; color: #6A5ACD;">Phí môi giới tạm tính</td>
            <td style="text-align: right; color: #BA55D3;">{phi_moi_gioi:,.0f} đ</td>
        </tr>
        <tr style="border-bottom: 1px solid #F3E5F5;">
            <td style="padding: 15px; color: #6A5ACD;">Thuế thu nhập cổ tức (5%)</td>
            <td style="text-align: right; color: #BA55D3;">{thue_co_tuc_tong:,.0f} đ</td>
        </tr>
        <tr style="background-color: #FDF5FF;">
            <td style="padding: 15px; font-weight: bold; color: #4B0082;">Giá điều chỉnh (Ex-dividend)</td>
            <td style="text-align: right; color: #9370DB; font-size: 1.2em;"><b>{gia_dieu_chinh:,.0f} đ/CP</b></td>
        </tr>
    </table>
    </div>
    """, unsafe_allow_html=True)

    st.write("---")
    st.subheader("💡 ĐỊNH HƯỚNG QUẢN TRỊ")
    
    if roi >= 15:
        st.info(f"🔮 **STRATEGY: RETAIN POSITION**\n\nBiên lợi nhuận {roi:.2f}% rất lý tưởng. Việc nắm giữ để nhận cổ tức giúp tối ưu hóa thuế phí dựa trên vị thế giá vốn sẵn có. Đây là thời điểm để gia tăng quy mô tài sản tĩnh lặng.")
    elif roi < 0:
        st.error(f"🔮 **STRATEGY: RE-STRUCTURE**\n\nVị thế hiện tại đang âm. Tác động của thuế khấu trừ cổ tức có thể làm tăng mức lỗ thực tế. Cân nhắc tái cấu trúc danh mục để bảo vệ dòng tiền.")
    else:
        st.warning(f"🔮 **STRATEGY: NEUTRAL**\n\nVùng giá nhạy cảm. Nhà đầu tư nên quan sát phản ứng tại ngưỡng giá điều chỉnh {gia_dieu_chinh:,.0f}đ trước khi ra quyết định tiếp theo.")

