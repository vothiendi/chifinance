# --- KHỐI NHẬP LIỆU ---
st.subheader("📋 TRẠNG THÁI VỊ THẾ")
with st.container():
    c1, c2 = st.columns(2)
    with c1:
        ticker = st.text_input("MÃ TÀI SẢN", value="VND").upper()
        so_luong = st.number_input("KHỐI LƯỢNG NẮM GIỮ", value=10000, step=1000)
    with c2:
        gia_von = st.number_input("GIÁ VỐN BÌNH QUÂN", value=25000)
        gia_ban = st.number_input("GIÁ THỊ TRƯỜNG HIỆN TẠI", value=32000)

# Tính toán ROI
roi = ((gia_ban / gia_von) - 1) * 100
st.write("")
col_m1, col_m2 = st.columns(2)
col_m1.metric("LỢI NHUẬN TỰ THÂN", f"{(gia_ban - gia_von) * so_luong:,.0f} VNĐ")
col_m2.metric("TỶ SUẤT (ROI)", f"{roi:.2f}%")

# --- THÔNG TIN QUYỀN LỢI ---
st.subheader("✨ TỐI ƯU HÓA QUYỀN LỢI")
c3, c4 = st.columns(2)
with c3:
    div_cash_rate = st.number_input("Cổ tức tiền mặt (%)", value=15.0)
    phi_gd = st.number_input("Phí môi giới (%)", value=0.1) / 100
with c4:
    div_stock_rate = st.number_input("Cổ tức cổ phiếu (%)", value=10.0)

if st.button("XUẤT BÁO CÁO CHIẾN LƯỢC"):
    # Tính toán chuẩn xác theo công thức của Chi
    gia_tri_ban = so_luong * gia_ban
    thue_ban = 0.001 * gia_tri_ban # Thuế 0.1%
    phi_moi_gioi = phi_gd * gia_tri_ban
    
    tien_mat_moi_cp = 10000 * (div_cash_rate / 100)
    thue_co_tuc_tong = (so_luong * tien_mat_moi_cp) * 0.05 # Thuế 5%
    
    gia_dieu_chinh = (gia_ban - tien_mat_moi_cp) / (1 + (div_stock_rate/100))

    st.write("---")
    st.write("### 📜 ĐỊNH LƯỢNG CHI PHÍ & VỊ THẾ")
    
    st.markdown(f"""
    <div class="report-box">
    <table style="width:100%; border-collapse: collapse; font-family: 'Segoe UI', sans-serif;">
        <tr style="border-bottom: 1px solid #F3E5F5;">
